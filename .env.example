# Copy to .env.local for local dev.
VITE_API_BASE_URL=http://localhost:9090

# Module feature flags — flip to false to disable an entire module.
VITE_MODULE_AUTH=true
VITE_MODULE_IAM=true
VITE_MODULE_EXAMS=true

# AUTH module internal features
VITE_AUTH_LOGIN=true
VITE_AUTH_PASSWORD_RESET=true
VITE_AUTH_SESSIONS=true

# IAM module internal features
VITE_IAM_USERS=true
VITE_IAM_ROLES=true
VITE_IAM_PERMISSIONS=true
VITE_IAM_ORGANIZATIONS=true
VITE_IAM_AUDIT_LOG=true
VITE_IAM_PROFILE=true

# EXAMS module internal features
VITE_EXAMS_EXAM_SCHEDULES=true
VITE_EXAMS_GRADES=true
VITE_EXAMS_REPORT_CARDS=true
